[importlinter]
root_packages =
    d810
    tests
include_external_packages = True
exclude_type_checking_imports = True

[importlinter:contract:unit-tests-no-hexrays]
name = Unit tests must not import hexrays modules
type = forbidden
source_modules =
    tests.unit
forbidden_modules =
    d810.hexrays
ignore_imports =
    tests.unit.test_mop_snapshot_guard -> d810.hexrays.mop_snapshot
    # portable_cfg and microcode_constants are IDA-free at module level (guarded try/except)
    tests.unit.recon.test_cfg_shape -> d810.hexrays.portable_cfg
    tests.unit.recon.test_dispatch_pattern -> d810.hexrays.portable_cfg
    tests.unit.recon.test_dispatch_pattern -> d810.recon.collectors.dispatch_pattern
    tests.unit.recon.test_opcode_distribution -> d810.hexrays.portable_cfg
    # test_hook_integration uses ast.parse / inspect.getsource only (no IDA runtime)
    tests.unit.recon.test_hook_integration -> d810.hexrays.ctree_hooks

[importlinter:contract:unit-tests-no-ui]
name = Unit tests must not import ui modules
type = forbidden
source_modules =
    tests.unit
forbidden_modules =
    d810.ui

[importlinter:contract:unit-tests-no-optimizers]
name = Unit tests must not import optimizers modules
type = forbidden
source_modules =
    tests.unit
forbidden_modules =
    d810.optimizers
ignore_imports =
    # test_hook_integration uses AST inspection; ctree_hooks -> handler is guarded
    tests.unit.recon.test_hook_integration -> d810.hexrays.ctree_hooks

[importlinter:contract:actions-no-direct-ida-imports]
name = Actions modules must not directly import IDA packages
type = forbidden
allow_indirect_imports = True
source_modules =
    d810.ui.actions
forbidden_modules =
    idaapi
    ida_kernwin
    ida_hexrays
    ida_loader
    ida_funcs
    ida_fpro
    ida_lines
    idc
    idautils
    idapro
