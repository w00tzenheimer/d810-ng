[importlinter]
root_packages =
    d810
    tests
include_external_packages = True
exclude_type_checking_imports = True

[importlinter:contract:unit-tests-no-hexrays]
name = Unit tests must not import hexrays modules
type = forbidden
source_modules =
    tests.unit
forbidden_modules =
    d810.hexrays

[importlinter:contract:unit-tests-no-ui]
name = Unit tests must not import ui modules
type = forbidden
source_modules =
    tests.unit
forbidden_modules =
    d810.ui

[importlinter:contract:unit-tests-no-optimizers]
name = Unit tests must not import optimizers modules
type = forbidden
source_modules =
    tests.unit
forbidden_modules =
    d810.optimizers
ignore_imports =
    tests.unit.optimizers.microcode.flow.flattening.hodur.test_provenance -> d810.optimizers.microcode.flow.flattening.hodur.provenance
[importlinter:contract:layered-architecture]
name = Layered architecture prevents upward imports
type = layers
layers =
    d810.ui
    d810.optimizers
    d810.recon
    d810.backends
    d810.evaluator
    d810.hexrays
    d810.mba
    d810.cfg
    d810.core
    d810.errors
ignore_imports =
    d810.backends.ast.z3 -> d810.recon.flow.def_search

[importlinter:contract:mba-core-no-hexrays]
name = MBA core must not import hexrays
type = forbidden
allow_indirect_imports = True
source_modules =
    d810.mba
    d810.mba.rules
forbidden_modules =
    d810.hexrays

[importlinter:contract:actions-no-direct-ida-imports]
name = Actions modules must not directly import IDA packages
type = forbidden
allow_indirect_imports = True
source_modules =
    d810.ui.actions
forbidden_modules =
    idaapi
    ida_kernwin
    ida_hexrays
    ida_loader
    ida_funcs
    ida_fpro
    ida_lines
    idc
    idautils
    idapro

[importlinter:contract:recon-core-no-hexrays]
name = Recon core modules must stay hexrays-agnostic
type = forbidden
allow_indirect_imports = True
source_modules =
    d810.recon.analysis
    d810.recon.models
    d810.recon.phase
    d810.recon.store
    d810.recon.collectors
    d810.recon.flow.analysis_stats
    d810.recon.flow.dispatch_region
    d810.recon.flow.profile_classifier
    d810.recon.flow.bst_model
forbidden_modules =
    d810.hexrays

[importlinter:contract:hexrays-subsystems-no-hooks]
name = Hexrays subsystems must not depend on hooks
type = forbidden
allow_indirect_imports = True
source_modules =
    d810.hexrays.ir
    d810.hexrays.mutation
    d810.hexrays.utils
    d810.hexrays.expr
forbidden_modules =
    d810.hexrays.hooks
