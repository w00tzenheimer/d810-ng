[importlinter]
root_packages =
    d810
    tests
include_external_packages = True
exclude_type_checking_imports = True

[importlinter:contract:unit-tests-no-hexrays]
name = Unit tests must not import hexrays modules
type = forbidden
source_modules =
    tests.unit
forbidden_modules =
    d810.hexrays

[importlinter:contract:unit-tests-no-ui]
name = Unit tests must not import ui modules
type = forbidden
source_modules =
    tests.unit
forbidden_modules =
    d810.ui

[importlinter:contract:unit-tests-no-optimizers]
name = Unit tests must not import optimizers modules
type = forbidden
source_modules =
    tests.unit
forbidden_modules =
    d810.optimizers

[importlinter:contract:layered-architecture]
name = Layered architecture prevents upward imports
type = layers
layers =
    d810.ui
    d810.diagnostics
    d810.optimizers
    d810.recon
    d810.backends
    d810.evaluator
    d810.hexrays
    d810.mba
    d810.cfg
    d810.core
    d810.errors

[importlinter:contract:mba-core-no-hexrays]
name = MBA core must not import hexrays
type = forbidden
allow_indirect_imports = True
source_modules =
    d810.mba
    d810.mba.rules
forbidden_modules =
    d810.hexrays

[importlinter:contract:actions-no-direct-ida-imports]
name = Actions modules must not directly import IDA packages
type = forbidden
allow_indirect_imports = True
source_modules =
    d810.ui.actions
forbidden_modules =
    idaapi
    ida_kernwin
    ida_hexrays
    ida_loader
    ida_funcs
    ida_fpro
    ida_lines
    idc
    idautils
    idapro

[importlinter:contract:recon-core-no-hexrays]
name = Recon core modules must stay hexrays-agnostic
type = forbidden
allow_indirect_imports = True
source_modules =
    d810.recon.analysis
    d810.recon.models
    d810.recon.phase
    d810.recon.store
    d810.recon.collectors
    d810.recon.flow.analysis_stats
    d810.recon.flow.dispatch_region
    d810.recon.flow.profile_classifier
    d810.recon.flow.bst_model
forbidden_modules =
    d810.hexrays

[importlinter:contract:hexrays-subsystems-no-hooks]
name = Hexrays subsystems must not depend on hooks
type = forbidden
allow_indirect_imports = True
source_modules =
    d810.hexrays.ir
    d810.hexrays.mutation
    d810.hexrays.utils
    d810.hexrays.expr
forbidden_modules =
    d810.hexrays.hooks

[importlinter:contract:runtime-no-core-diag]
# Runtime layers must route diagnostic capture through the
# observability facades, not import d810.core.diag directly.
#
# Allowed transient exceptions (handled via ignore_imports):
#  - d810.recon.observability, d810.cfg.observability,
#    d810.hexrays.observability re-export from d810.core.diag.* by
#    design; they ARE the boundary.
#  - d810.cfg.provenance registers its drain callback with the
#    core.diag IoC hook (`register_provenance_drainer`) at import time
#    so `snapshot_mba` can pull buffered entries without core.diag
#    importing from d810.cfg (forbidden by layers). This is the same
#    pattern d810.cfg.block_lineage uses for `register_lineage_drainer`.
#  - d810.hexrays.hooks.hexrays_hooks bootstraps the diag event-handler
#    subscribers when a diag session opens and unsubscribes them when
#    it closes. The bootstrap is a one-call orchestration concern; the
#    runtime hot path never touches core.diag.
#
# d810.diagnostics is the post-hoc CLI/query layer and is allowed to
# read from core.diag; it is excluded by being absent from
# source_modules.
name = Runtime code must not import core diag directly
type = forbidden
allow_indirect_imports = True
source_modules =
    d810.manager
    d810.optimizers
    d810.recon
    d810.cfg
    d810.hexrays
forbidden_modules =
    d810.core.diag
ignore_imports =
    d810.recon.observability -> d810.core.diag
    d810.recon.observability -> d810.core.diag.snapshot
    d810.cfg.observability -> d810.core.diag
    d810.cfg.observability -> d810.core.diag.snapshot
    d810.hexrays.observability -> d810.core.diag
    d810.hexrays.observability -> d810.core.diag.snapshot
    d810.cfg.provenance -> d810.core.diag
    d810.hexrays.hooks.hexrays_hooks -> d810.core.diag.event_handlers
